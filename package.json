{
  "name": "@lorb/visibility-auto",
  "version": "0.1.0",
  "description": "Long pages render instantly. Automatic content-visibility:auto for every element",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "content-visibility",
    "performance",
    "rendering",
    "css",
    "contain-intrinsic-size",
    "lazy-render"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "homepage": "https://github.com/lorb-studio/visibility-auto",
  "author": "Lorb.studio <dev@lorb.studio> (https://lorb.studio)",
  "repository": {
    "type": "git",
    "url": "https://github.com/lorb-studio/visibility-auto"
  }
}
